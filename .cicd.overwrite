---

# Generic
generic:
  role: ansible-role-rsyslog
  role_short: rsyslog
  role_description: |
    Install/manages rsyslog on various platforms 
  collections: []

# Supported platforms
platforms:
  sles15:
    supported: true
    ci: false
  sles16:
    supported: true
    ci: false
  opensuse15:
    supported: true
    ci: true
  opensuse16:
    supported: true
    ci: true
  ubuntu2004:
    supported: true
    ci: true

molecule:
  requirements:
    roles_extra: []
